{
  "extends": "../../packages/config/tsconfig.expo.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    {
      "path": "../../packages/tokens"
    },
    {
      "path": "../../packages/types"
    },
    {
      "path": "../../packages/mock-data"
    }
  ]
}
